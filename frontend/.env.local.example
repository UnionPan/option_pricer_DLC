# Local Environment Configuration
#
# Copy this file to .env.local to override default settings for local development
# .env.local is gitignored and won't be committed
#
# Example: To use a different backend server:
# REACT_APP_API_URL=http://192.168.1.100:8000/api/v1
#
# Or to use a remote backend:
# REACT_APP_API_URL=https://your-backend.com/api/v1

REACT_APP_API_URL=http://localhost:8000/api/v1
